# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# For one-shot runs (cron/GitHub Actions):
# true  -> send message for both states (available and no appointments)
# false -> send message only when available or on errors
SEND_NO_APPOINTMENT_MESSAGE=true

# Check interval in seconds (default: 3600 = 1 hour)
CHECK_INTERVAL=3600
