# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
BOT_LABEL=City X Appointment Bot
APPOINTMENT_LINK=https://example.com/appointments
BOOKING_URL=https://example.com/appointments

# For one-shot runs (cron):
# true  -> send message for both states (available and no appointments)
# false -> send message only when appointments are available
SEND_NO_APPOINTMENT_MESSAGE=false

# Used only by bot.py (long-running mode)
# Check interval in seconds (default: 300 = 5 minutes)
CHECK_INTERVAL=300
