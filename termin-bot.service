[Unit]
Description=City X Appointment Bot for Telegram
After=network.target
Documentation=https://github.com/yourusername/termin_bot/blob/main/README.md

[Service]
Type=simple
User=%u
WorkingDirectory=%h/termin_bot
Environment="PATH=%h/termin_bot/venv/bin"
Environment="PYTHONUNBUFFERED=1"
ExecStart=%h/termin_bot/venv/bin/python %h/termin_bot/bot.py
Restart=on-failure
RestartSec=60
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
